{
  "name": "vertiport-eval",
  "version": "0.1.0",
  "private": true,
  "description": "eVTOL vertiport site feasibility evaluation tool",
  "author": "BUSINESSAVIATION.AERO <bright@zumbador.com>",
  "license": "MIT",
  "homepage": "https://github.com/zumbador/vertiport-eval",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"cross-env NODE_ENV=development electron .\" --kill-others-on-fail",
    "electron:preview": "vite build && electron .",
    "dist:linux": "vite build && electron-builder --linux",
    "dist:deb": "vite build && electron-builder --linux deb",
    "dist:appimage": "vite build && electron-builder --linux AppImage",
    "dist:win": "vite build && electron-builder --win",
    "dist:mac": "vite build && electron-builder --mac",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.21",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^4.1.4",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "jspdf": "^4.2.1",
    "leaflet": "^1.9.4",
    "mapbox-gl": "^3.20.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-leaflet": "^4.2.1",
    "vite": "^5.4.14",
    "vitest": "^4.1.4"
  },
  "build": {
    "appId": "aero.lowaltitudeeconomy.vertiport-eval",
    "productName": "Vertiport Eval",
    "copyright": "Copyright © 2026 BUSINESSAVIATION.AERO",
    "asar": true,
    "directories": {
      "app": ".",
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "linux": {
      "target": [
        "deb",
        "AppImage"
      ],
      "icon": "build/icon.png",
      "category": "Science",
      "description": "eVTOL vertiport site feasibility evaluation tool",
      "maintainer": "BUSINESSAVIATION.AERO <bright@zumbador.com>"
    },
    "deb": {
      "packageCategory": "science"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    },
    "mac": {
      "target": "dmg",
      "icon": "build/icon.png",
      "category": "public.app-category.productivity"
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    }
  }
}
