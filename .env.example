# ── AI Provider ────────────────────────────────────────────────
# Desktop app (Electron): set via the BYOK setup screen on first launch.
# Web / dev mode only: set one of the keys below.
VITE_ANTHROPIC_API_KEY=
# VITE_OPENAI_API_KEY=       # not used directly — set via BYOK screen
# VITE_GEMINI_API_KEY=       # not used directly — set via BYOK screen

# ── Government data APIs (free registration) ───────────────────
VITE_EIA_API_KEY=            # https://www.eia.gov/opendata/
VITE_NREL_API_KEY=           # https://developer.nrel.gov/
VITE_MAPBOX_TOKEN=           # https://www.mapbox.com/ (3D obstacle map)

# ── Email gate (web beta only — not needed for Electron) ───────
VITE_ACYM_BASE_URL=           # e.g. https://yourdomain.com
VITE_ACYM_API_KEY=            # AcyMailing REST API key
VITE_ACYM_LIST_ID=            # AcyMailing list ID for free users
